{
    "version": "0.2.0",
    "configurations": [
        {
            // WARNING: This extension may not work well for MSVC-based builds or on certain versions of Windows.
            // Try using the native but proprietary "cppvsdbg" in regular VSCode,
            "name": "Launch (CodeLLDB) (Windows)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}\\bin\\victoria.exe",
            "args": [],
            "stopOnEntry": false,
            "cwd": "${workspaceFolder}\\bin\\",
            "env": {},
            "console": "integratedTerminal",
        },
        {
            "name": "Launch (CodeLLDB) (Linux)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/bin/victoria",
            "args": [],
            "stopOnEntry": false,
            "cwd": "${workspaceFolder}/bin/",
            "env": {},
        },
        {
            "name": "Launch (GDB) (Linux)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/victoria",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/bin/",
            "environment": [],
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing"
                },
                {
                    "description": "Load Victoria's pretty-printer values",
                    "text": "source ${workspaceFolder}/utils/gdb_print_pretty.py"
                },
                {
                    "description": "Set the debugging directory to its correct value",
                    "text": "directory ${workspaceFolder}"
                },
            ]
        }
    ]
}